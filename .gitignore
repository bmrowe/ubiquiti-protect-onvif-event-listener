# Bazel build outputs
bazel-bin
bazel-out
bazel-testlogs
bazel-ubiquiti-protect-onvif-event-listener

# Legacy make build artifacts
*.o
onvif_recorder
ubv_extract

# Test binaries (built by Bazel, not source)
test/test_detection_recorder
test/test_onvif_listener
test/test_ubv_thumbnail

# SQLite databases
*.db

# Log and event files
*.jsonl

# Keep test fixtures in testdata/
!test/testdata/
!test/testdata/*

# Thumbnails directory
thumbnails/

# Temporary/test UBV files
/tmp/*.ubv

# PGO profile data (generated, not committed — except the ARM64 release profile)
*.profraw
*.profdata
!pgo_arm64.profdata
.claude/
dist/

# Docker ARM64 build cache (records last successfully built commit SHA)
.docker_arm64_cache

# Stray Bazel sandbox artifact
bazel-build

# Downloaded model files (Bazel http_file rules fetch these at build time)
nanodet_m.bin
nanodet_m.param
